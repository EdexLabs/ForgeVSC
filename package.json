{
  "name": "forgescript",
  "displayName": "ForgeScript",
  "description": "Language support for Forgescript via ForgeLSP",
  "version": "2.0.5",
  "publisher": "EdexLabs",
  "icon": "icon.png",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/EdexLabs/ForgeLSP"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "keywords": [
    "forge",
    "forgelsp",
    "botforge",
    "language-server"
  ],
  "activationEvents": [
    "workspaceContains:forgeconfig.json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "forgescript",
          "title": "ForgeScript",
          "icon": "$(symbol-function)"
        }
      ]
    },
    "views": {
      "forgescript": [
        {
          "id": "forgescript.explorerView",
          "name": "Explorer",
          "icon": "$(symbol-function)",
          "contextualTitle": "ForgeScript"
        }
      ]
    },
    "languages": [
      {
        "id": "forge",
        "aliases": [
          "Forge",
          "forge"
        ],
        "extensions": [
          ".forge"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "forge",
        "scopeName": "source.forge",
        "path": "./syntaxes/forge.tmLanguage.json"
      },
      {
        "scopeName": "forge.injection",
        "path": "./syntaxes/forge-injection.tmLanguage.json",
        "injectTo": [
          "source.js",
          "source.ts"
        ]
      }
    ],
    "commands": [
      {
        "command": "forgescript.createConfig",
        "title": "ForgeScript: Create forgeconfig.json"
      },
      {
        "command": "forgescript.restart",
        "title": "ForgeScript: Restart Server"
      },
      {
        "command": "forgescript.forceUpdate",
        "title": "ForgeScript: Force Update Binary"
      },
      {
        "command": "forgescript.setCustomBinary",
        "title": "ForgeScript: Set Custom Binary Path"
      },
      {
        "command": "forgescript.resetBinary",
        "title": "ForgeScript: Reset to Official Binary"
      },
      {
        "command": "forgescript.showVersion",
        "title": "ForgeScript: Show Version"
      },
      {
        "command": "forgescript.showStatus",
        "title": "ForgeScript: Show Status"
      },
      {
        "command": "forgescript.openLog",
        "title": "ForgeScript: Open Output Log"
      },
      {
        "command": "forgescript.checkForUpdates",
        "title": "ForgeScript: Check for Updates"
      },
      {
        "command": "forgescript.reloadConfig",
        "title": "ForgeScript: Reload forgeconfig.json"
      },
      {
        "command": "forgescript.openConfig",
        "title": "ForgeScript: Open forgeconfig.json"
      },
      {
        "command": "forgescript.stop",
        "title": "ForgeScript: Stop Server"
      },
      {
        "command": "forgescript.start",
        "title": "ForgeScript: Start Server"
      },
      {
        "command": "forgescript.openGuide",
        "title": "ForgeScript: Open Guide",
        "icon": "$(book)"
      },
      {
        "command": "forgescript.favoriteGuide",
        "title": "ForgeScript: Add to Favorites",
        "icon": "$(star-empty)"
      },
      {
        "command": "forgescript.unfavoriteGuide",
        "title": "ForgeScript: Remove from Favorites",
        "icon": "$(star-full)"
      },
      {
        "command": "forgescript.openGuideExternal",
        "title": "ForgeScript: Open Guide on Docs Site",
        "icon": "$(link-external)"
      },
      {
        "command": "forgescript.searchGuides",
        "title": "ForgeScript: Search Guides",
        "icon": "$(search)"
      },
      {
        "command": "forgescript.reloadGuides",
        "title": "ForgeScript: Reload Guides",
        "icon": "$(refresh)"
      },
      {
        "command": "forgescript.openFunctionDocs",
        "title": "ForgeScript: Open Function Docs",
        "icon": "$(symbol-function)"
      },
      {
        "command": "forgescript.searchFunctions",
        "title": "ForgeScript: Search Functions",
        "icon": "$(search)"
      },
      {
        "command": "forgescript.reloadFunctions",
        "title": "ForgeScript: Reload Functions",
        "icon": "$(refresh)"
      },
      {
        "command": "forgescript.openEnumDocs",
        "title": "ForgeScript: Open Enum Docs",
        "icon": "$(symbol-enum)"
      },
      {
        "command": "forgescript.openEventDocs",
        "title": "ForgeScript: Open Event Docs",
        "icon": "$(symbol-event)"
      },
      {
        "command": "forgescript.search",
        "title": "ForgeScript: Search",
        "icon": "$(search)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "forgescript.createConfig"
        },
        {
          "command": "forgescript.restart"
        },
        {
          "command": "forgescript.forceUpdate"
        },
        {
          "command": "forgescript.setCustomBinary"
        },
        {
          "command": "forgescript.resetBinary"
        },
        {
          "command": "forgescript.showVersion"
        },
        {
          "command": "forgescript.showStatus"
        },
        {
          "command": "forgescript.openLog"
        },
        {
          "command": "forgescript.checkForUpdates"
        },
        {
          "command": "forgescript.reloadConfig"
        },
        {
          "command": "forgescript.openConfig"
        },
        {
          "command": "forgescript.stop"
        },
        {
          "command": "forgescript.start"
        },
        {
          "command": "forgescript.searchFunctions"
        },
        {
          "command": "forgescript.searchGuides"
        },
        {
          "command": "forgescript.reloadFunctions"
        },
        {
          "command": "forgescript.reloadGuides"
        },
        {
          "command": "forgescript.openFunctionDocs",
          "when": "false"
        },
        {
          "command": "forgescript.openEnumDocs",
          "when": "false"
        },
        {
          "command": "forgescript.openEventDocs",
          "when": "false"
        },
        {
          "command": "forgescript.openGuide",
          "when": "false"
        },
        {
          "command": "forgescript.openGuideExternal",
          "when": "false"
        },
        {
          "command": "forgescript.favoriteGuide",
          "when": "false"
        },
        {
          "command": "forgescript.unfavoriteGuide",
          "when": "false"
        },
        {
          "command": "forgescript.search"
        }
      ],
      "view/title": [
        {
          "command": "forgescript.searchFunctions",
          "when": "view == forgescript.explorerView",
          "group": "navigation"
        },
        {
          "command": "forgescript.reloadFunctions",
          "when": "view == forgescript.explorerView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "forgescript.favoriteGuide",
          "when": "view == forgescript.explorerView && viewItem == guide",
          "group": "inline"
        },
        {
          "command": "forgescript.unfavoriteGuide",
          "when": "view == forgescript.explorerView && viewItem == guide.favorite",
          "group": "inline"
        },
        {
          "command": "forgescript.openGuideExternal",
          "when": "view == forgescript.explorerView && (viewItem == guide || viewItem == guide.favorite)",
          "group": "inline"
        },
        {
          "command": "forgescript.favoriteGuide",
          "when": "view == forgescript.explorerView && viewItem == guide",
          "group": "guides@1"
        },
        {
          "command": "forgescript.unfavoriteGuide",
          "when": "view == forgescript.explorerView && viewItem == guide.favorite",
          "group": "guides@1"
        },
        {
          "command": "forgescript.openGuideExternal",
          "when": "view == forgescript.explorerView && (viewItem == guide || viewItem == guide.favorite)",
          "group": "guides@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "forgescript.search",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.4.0"
  }
}